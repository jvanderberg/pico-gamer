VFILTER 4, 208, 18, FILTER_LP
VDRIVE 4, 84

VFILTER 5, 220, 18, FILTER_HP

FILTER 214, 10, FILTER_LP

running = 1
btn_held = 0

SUB start_music()
  MPLAY zelda_theme
  running = 1
END SUB

SUB stop_music()
  MSTOP
  running = 0
END SUB

start_music

DO
  inp = INPUT()

  IF inp AND INPUT_BTN THEN
    IF btn_held = 0 THEN
      btn_held = 1
      IF running = 1 THEN
        stop_music
      ELSE
        start_music
      END IF
    END IF
  ELSE
    btn_held = 0
  END IF

  CLEAR
  TEXT_LG "ZELDA", 38, 6
  TEXT_SM "OVERWORLD", 28, 24
  TEXT_SM "BTN TOGGLE", 28, 38
  TEXT_SM "6 VOICE ARRANGE", 14, 50
  YIELD
LOOP
